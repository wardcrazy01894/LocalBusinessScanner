# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it's in .gitignore.

# ── Data source ──────────────────────────────────────────────────────────────
#
# MODE A: Google Places (recommended for best coverage)
#   - Requires billing account but has $200/month free credit
#   - POC scan (50 businesses, 1 km) costs ~$0.95 — easily within free tier
#   - Get a key: https://console.cloud.google.com/apis/credentials
#   - Enable "Places API" in your Google Cloud project
#
GOOGLE_MAPS_API_KEY=
#
# MODE B: Free sources (Overpass/OSM + Yelp) — used if GOOGLE_MAPS_API_KEY is empty
#   - Overpass/OSM: completely free, no key needed, runs automatically
#   - Yelp: free key at https://www.yelp.com/developers — adds food/retail coverage
#   - Coverage is lower than Google but costs nothing
#
YELP_API_KEY=

# ── Optional tuning (defaults shown) ─────────────────────────────────────────
# DB_PATH=data/scanner.db
# REPORTS_DIR=reports
# LOG_LEVEL=INFO
# CHECK_CONCURRENCY=10
# PLACE_DETAILS_DELAY_S=0.15
# WEBSITE_CHECK_TIMEOUT_S=10
# STALENESS_DAYS=7
